@using CyberQuiz.UI.Data
@using Microsoft.AspNetCore.Components.Authorization
@using CyberQuiz.Shared.DTOs
@using System.Security.Claims
@using CyberQuiz.UI.Services
@using Microsoft.AspNetCore.Identity
@inject AuthenticationStateProvider AuthStateProvider
@inject IQuizApiClient QuizApi
@inject UserManager<ApplicationUser> UserManager
@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 py-2 d-flex align-items-center">

            <!--Visar olika beroende på vem som är inloggad eller om user ens är inloggad-->
            <AuthorizeView>
                <!--Om inloggad körs detta-->
                <Authorized Context="auth">

                    <div class="me-auto">
                        👤 @userEmail
                    </div>
                
                    @if (progress != null)
                    {
                        <div class="progress-wrapper text-center">

                            <div class="progress" style="height: 20px; width:250px;">
                                <div class="progress-bar bg-success"
                                    role="progressbar"
                                     style="width:@($"{progress.OverallPercent}%")">
                                </div>
                            </div>
                            <!--Visar hur många subcategories som är klarade av totalt antal subcategories-->
                            <small class="progress-label">
                                Progress (@progress.CompletedSubCategories / @progress.TotalSubCategories)
                            </small>

                        </div>
                        
                    }
                </Authorized>

                <NotAuthorized>

                    <a href="/Account/Login" class="btn btn-outline-primary btn-sm me-2">
                        Login
                    </a>

                    <a href="/Account/Register" class="btn btn-outline-secondary btn-sm">
                        Register
                    </a>

                </NotAuthorized>
            </AuthorizeView>

        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {

    private string? userEmail;

    //Variabel som lagrar progressdata från API
    private UserProgressDto? progress;

    //när layout laddas
    protected override async Task OnInitializedAsync()
    {
        //använder blazor identity för authentisering
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userPrincipal = authState.User;

        //user Id för unik progress overview
        var userId = userPrincipal.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (userId != null)
        {
            progress = await QuizApi.GetUserProgressAsync(userId);

            var user = await UserManager.GetUserAsync(userPrincipal);
            userEmail = user?.Email;
        }
    }

}
